# Server Configuration
PORT=3001
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/taskmanager
MONGODB_AI_DB=taskmanager_ai

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# OpenAI / Mastra
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_EXECUTIVE_MODEL=openai/gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG (disable change streams on standalone MongoDB)
# DISABLE_RAG_STREAMS=true

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here

# Admin Configuration
ADMIN_INVITE_TOKEN=your_admin_invite_token_here

# Client Configuration
CLIENT_URL=http://localhost:5173

# Production URLs (uncomment for production)
# CLIENT_URL=https://yourdomain.com
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/taskmanager
