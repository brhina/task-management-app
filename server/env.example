# Server Configuration
PORT=3001
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/taskmanager
MONGODB_AI_DB=taskmanager_ai

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# OpenRouter (free-tier models via OpenAI-compatible API)
# Get a key at https://openrouter.ai/keys
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=your_openrouter_api_key_here
# Free models — append :free or use openrouter/free for auto-selection
OPENROUTER_MODEL=nvidia/nemotron-nano-9b-v2:free
OPENROUTER_EXECUTIVE_MODEL=nvidia/nemotron-nano-9b-v2:free
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# RAG (disable change streams on standalone MongoDB)
# DISABLE_RAG_STREAMS=true

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here

# Admin Configuration
ADMIN_INVITE_TOKEN=your_admin_invite_token_here

# Client Configuration
CLIENT_URL=http://localhost:5173

# Production URLs (uncomment for production)
# CLIENT_URL=https://yourdomain.com
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/taskmanager
